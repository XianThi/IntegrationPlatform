{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "ApiBaseUrl": "https://localhost:7000",
    "NodeName": "Worker-01",
    "HeartbeatIntervalSeconds": 30,
    "WorkflowPollingIntervalSeconds": 60,
    "AdaptersPath": "Adapters",
    "AutoRegisterPlugins": true,
    "MaxConcurrentWorkflows": 5,
    "EnableMetricsCollection": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
